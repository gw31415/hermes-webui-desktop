{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes WebUI",
  "version": "0.1.0",
  "identifier": "com.local.hermes-webui-desktop",
  "build": {
    "frontendDist": "frontend"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "hermes-webui"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hermes WebUI",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  }
}
